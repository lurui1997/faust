---
import ProjectIndex from '../components/ProjectIndex.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../lib/projects.js';
---

<BaseLayout>
  <main id="content">
    <h1>Ideas, kept in public.</h1>
    <p>A working archive of small tools, unfinished questions, and things worth returning to.</p>
    <ProjectIndex projects={projects} instanceId="home-projects" />
  </main>
</BaseLayout>
