---
import type { GalleryProject } from '../../../../tools/generate-project-index.js';
import ProjectCover from '../../components/ProjectCover.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../lib/projects.js';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}

type Props = { project: GalleryProject };
const { project } = Astro.props;
---

<BaseLayout title={`${project.title} — Faust`} description={project.summary}>
  <main id="content">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href={import.meta.env.BASE_URL}>← All projects</a></nav>
    <article>
      <header class="project-header">
        <p class="eyebrow">{project.type} / {project.status} / {project.year}</p>
        <h1>{project.title}</h1>
        <p class="summary">{project.summary}</p>
      </header>
      <ProjectCover title={project.title} coverHref={project.coverHref} />
      <dl class="project-facts">
        <div><dt>Created</dt><dd><time datetime={project.createdAt}>{project.createdAt}</time></dd></div>
        <div><dt>Updated</dt><dd><time datetime={project.updatedAt}>{project.updatedAt}</time></dd></div>
        <div><dt>Tags</dt><dd>{project.tags.join(', ') || 'None'}</dd></div>
      </dl>
      <section class="about" aria-labelledby="excerpt-heading">
        <h2 id="excerpt-heading">About</h2>
        <div class="excerpt" set:html={project.excerptHtml} />
      </section>
      <footer class="project-actions" aria-label="Project links">
        {project.demo && <a href={project.demo}>View demo ↗</a>}
        <a href={project.sourceHref}>View source ↗</a>
      </footer>
    </article>
  </main>
</BaseLayout>

<style>
  .breadcrumb { margin-bottom: var(--space-2xl); font-size: .875rem; }
  .breadcrumb a { display: inline-flex; align-items: center; min-height: 2.75rem; }
  article { min-width: 0; }
  .project-header { display: grid; gap: 1rem; }
  .project-header h1 { max-width: 13ch; margin: 0 0 1rem -.04em; font-size: var(--text-title); line-height: .86; overflow-wrap: anywhere; }
  .summary { max-width: 45ch; margin: 0; color: var(--ink-muted); font-size: 1.125rem; }
  .project-facts { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 9rem), 1fr)); gap: 1.5rem; padding-block: 2rem; border-block: 1px solid var(--rule); }
  .project-facts div { display: grid; align-content: start; gap: .25rem; min-width: 0; }
  dt { color: var(--ink-muted); font-size: .75rem; letter-spacing: .1em; text-transform: uppercase; }
  dd { margin: 0; font-variant-numeric: tabular-nums; overflow-wrap: anywhere; }
  .about { display: grid; gap: 1.5rem; padding-top: var(--space-2xl); }
  .about h2 { margin: 0; font-size: clamp(2rem, 5vw, 4rem); }
  .excerpt { max-width: 65ch; font-size: 1.0625rem; }
  .excerpt :global(a) { overflow-wrap: anywhere; }
  .project-actions { display: flex; flex-wrap: wrap; gap: .75rem 2rem; margin-top: var(--space-2xl); padding-top: 1.5rem; border-top: 1px solid var(--rule); }
  .project-actions a { display: inline-flex; align-items: center; min-height: 2.75rem; font-size: 1.125rem; }
  @media (min-width: 48.0625rem) {
    .project-header { grid-template-columns: minmax(9rem, .3fr) 1fr; }
    .project-header h1, .project-header .summary { grid-column: 2; }
    .project-header .summary { margin-left: 25%; }
    .about { grid-template-columns: minmax(9rem, .3fr) 1fr; }
    .excerpt { grid-column: 2; }
  }
</style>
