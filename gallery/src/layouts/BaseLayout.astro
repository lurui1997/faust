---
type Props = {
  title?: string;
  description?: string;
};

const {
  title = 'Faust — Project Archive',
  description = 'A quiet archive of software ideas, experiments, and finished work.',
} = Astro.props;
const homeHref = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root { color-scheme: light; font-family: ui-sans-serif, system-ui, sans-serif; color: #24282b; background: #f4f5f3; }
      * { box-sizing: border-box; }
      body { margin: 0; }
      a { color: inherit; }
      a:focus-visible, select:focus-visible { outline: 2px solid currentColor; outline-offset: 4px; }
      .skip-link { position: absolute; inset: 0 auto auto 0; padding: .75rem 1rem; background: #24282b; color: #f4f5f3; transform: translateY(-110%); }
      .skip-link:focus { transform: translateY(0); }
      .site-header, main { width: min(72rem, calc(100% - 2rem)); margin-inline: auto; }
      .site-header { padding-block: 1.25rem; border-bottom: 1px solid #b9beba; }
      main { padding-block: clamp(3rem, 8vw, 8rem); }
      h1, h2 { font-family: Iowan Old Style, Baskerville, Georgia, serif; font-weight: 400; }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header">
      <a href={homeHref} aria-label="Faust project archive home">Faust / Project Archive</a>
    </header>
    <slot />
  </body>
</html>
